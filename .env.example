# ═══════════════════════════════════════════════════════════════════════
# WALLETGO — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values as needed.
# The app runs fully offline with ZERO config — all values below are
# optional and only enhance functionality when provided.
# ═══════════════════════════════════════════════════════════════════════

# OpenAI (optional — falls back to template responses if absent)
OPENAI_API_KEY=

# JWT Secret (shared between data-service and backend gateway)
# Change this in production! The default is fine for hackathon demos.
JWT_SECRET=replace-with-a-long-random-secret

# Microservice URLs (defaults work for local development)
FORECAST_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002
DATA_SERVICE_URL=http://localhost:8003

# Supabase (required for data persistence)
# Frontend uses VITE_* vars; data-service writes use SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=https://ycorammzxxozorcymgyv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_TRANSACTIONS_TABLE=transactions
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# Frontend Supabase + API base (VITE_* exposed to browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_API_URL=

# Environment
ENVIRONMENT=development
