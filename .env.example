# ═══════════════════════════════════════════════════════════════════════
# WALLETGO — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values as needed.
# The app runs fully offline with ZERO config — all values below are
# optional and only enhance functionality when provided.
# ═══════════════════════════════════════════════════════════════════════

# Gemini (optional — falls back to template responses if absent)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Environment
ENVIRONMENT=development

# Microservice URLs (defaults work for local development)
FORECAST_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002
DATA_SERVICE_URL=http://localhost:8003

# JWT Secret (shared between data-service and backend gateway)
# Change this in production! The default is fine for hackathon demos.
JWT_SECRET=

# Supabase (optional)
# Keep SUPABASE_URL and VITE_SUPABASE_URL the same.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TRANSACTIONS_TABLE=transactions
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_ISSUER=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
